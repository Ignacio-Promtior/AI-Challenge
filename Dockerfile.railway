FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application source
COPY scraper.py ingest.py chain.py server.py entrypoint.railway.sh ./
RUN chmod +x entrypoint.railway.sh

# Single volume at /app/storage covers data/ + vectorstore/
# Ollama models live in the separate Ollama service on Railway
VOLUME ["/app/storage"]

EXPOSE 8000

ENTRYPOINT ["./entrypoint.railway.sh"]
